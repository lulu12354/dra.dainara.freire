# ==============================================================================
# ARQUIVO DE PERFORMANCE - DRA. DAINARA FREIRE (by Gemini Code Assist)
# ==============================================================================

# ------------------------------------------------------------------------------
# ETAPA 1: COMPRESSÃO GZIP/DEFLATE
# Comprime os arquivos de texto antes de enviar para o navegador.
# ------------------------------------------------------------------------------
<IfModule mod_deflate.c>
  # Força a compressão em arquivos que servidores mal configurados podem pular
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE font/opentype font/truetype image/svg+xml

  # Remove bugs de navegadores antigos
  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

# ------------------------------------------------------------------------------
# ETAPA 2: CACHE DE NAVEGADOR (LEVERAGE BROWSER CACHING)
# Diz ao navegador para guardar os arquivos por um longo período.
# ------------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                          "access plus 1 month"

  # HTML: Cache curto, pois pode mudar com mais frequência
  ExpiresByType text/html                 "access plus 1 hour"

  # Mídia: Cache de 1 ano (não mudam nunca)
  ExpiresByType image/gif                 "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/jpg                 "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/avif                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType video/mp4                 "access plus 1 year"

  # CSS, JS e Fontes: Cache de 1 ano
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType application/x-font-woff2  "access plus 1 year"
</IfModule>